DATABASE_URL=postgresql+asyncpg://postgres:yourpassword@localhost:5432/widgets
# Keep this enabled only for a local one-off schema bootstrap. Vercel should use
# a migration or one-off database job instead of creating tables on cold start.
AUTO_CREATE_SCHEMA=true
SECRET_KEY=replace-with-a-long-random-secret
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/google/callback
DEEP_LINK_REDIRECT=widgetapp://auth/callback
WEB_AUTH_REDIRECT_URI=http://localhost:5173/auth/callback
OPENAI_API_KEY=
OPENAI_BASE_URL=
AI_MODEL=gpt-4o-mini
AI_MAX_TOKENS=250
AI_TEMPERATURE=0.7
AI_TIMEOUT_SECONDS=30
