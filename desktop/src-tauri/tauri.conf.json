{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Widget Studio",
  "version": "0.1.0",
  "identifier": "com.codex.desktopwidgets",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "label": "main",
        "title": "Widget Studio",
        "width": 1200,
        "height": 760,
        "decorations": true,
        "transparent": false,
        "resizable": true,
        "alwaysOnTop": false,
        "skipTaskbar": false,
        "shadow": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "deep-link": {
      "schemes": [
        "widgetapp"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis"],
    "icon": ["icons/icon.ico", "icons/icon.png"]
  }
}
