{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Widget Studio",
  "version": "0.1.0",
  "identifier": "com.codex.desktopwidgets",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "label": "main",
        "title": "Widget Studio",
        "width": 1200,
        "height": 760,
        "decorations": false,
        "transparent": false,
        "resizable": true,
        "alwaysOnTop": false,
        "skipTaskbar": false,
        "shadow": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis"],
    "createUpdaterArtifacts": false,
    "icon": ["icons/icon.ico", "icons/icon.png"]
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": [
          "widgetapp"
        ]
      }
    },
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEI3REQwQzg3MUE0NjFERUIKUldUckhVWWFod3pkdDAvYnM2enpOMUhEeUwrTlV4Q1E2VWs1cWo2Rm1yc3dKMFU3YUVOcUtidlQK",
      "endpoints": [
        "https://github.com/susin-d/Widget-Studio/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
